# Bartleby configuration. Copy to .env and edit.
# Only BARTLEBY_AUTH_TOKEN is required; the rest have sensible defaults.

# Bearer token shared by the REST API and the MCP endpoint. REQUIRED.
# Use a long random secret, e.g.: openssl rand -hex 32
BARTLEBY_AUTH_TOKEN=

# Where notes are stored on disk (inside the container by default).
BARTLEBY_VAULT_PATH=/data/vault

# Bind address and port.
BARTLEBY_HOST=0.0.0.0
BARTLEBY_PORT=8080

# Days a soft-deleted note stays in .trash/ before it is purged.
BARTLEBY_TRASH_RETENTION_DAYS=30

# SQLite FTS5 index location. Defaults to <vault>/.bartleby/index.db if unset.
# BARTLEBY_INDEX_PATH=/data/vault/.bartleby/index.db

# Comma-separated allowed origins for the browser extension and web UI (CORS).
# Leave empty if the UI is served same-origin and you don't use the extension
# cross-origin. Example: chrome-extension://<id>,https://bartleby.example.com
BARTLEBY_CORS_ORIGINS=

# Log verbosity: debug | info | warning | error
BARTLEBY_LOG_LEVEL=info
