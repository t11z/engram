# Engram configuration. Copy to .env and edit.
# Only ENGRAM_AUTH_TOKEN is required; the rest have sensible defaults.

# Bearer token shared by the REST API and the MCP endpoint. REQUIRED.
# Use a long random secret, e.g.: openssl rand -hex 32
ENGRAM_AUTH_TOKEN=

# Where notes are stored on disk (inside the container by default).
ENGRAM_VAULT_PATH=/data/vault

# Bind address and port.
ENGRAM_HOST=0.0.0.0
ENGRAM_PORT=8080

# Days a soft-deleted note stays in .trash/ before it is purged.
ENGRAM_TRASH_RETENTION_DAYS=30

# SQLite FTS5 index location. Defaults to <vault>/.engram/index.db if unset.
# ENGRAM_INDEX_PATH=/data/vault/.engram/index.db

# --- Convention-based vault behaviour (v2) ---
# Stamp a ULID `id` into notes Engram creates (rename-stable handle for clients).
# Off by default; Engram never injects an id into notes that lack one.
ENGRAM_INJECT_ID=false

# Sub-folder where Engram places notes it creates. Empty = vault root.
ENGRAM_NEW_NOTE_DIR=

# Folder treated as the attachment store (served via the attachments endpoints).
ENGRAM_ATTACHMENT_DIR=

# Folder for daily notes (used by the daily-note append surfaces).
ENGRAM_DAILY_NOTE_DIR=

# Live-reconcile the vault with a filesystem watcher while running, so external
# or replicated changes are picked up promptly. Engram does not sync the vault
# across machines (see docs: Deployment topologies).
ENGRAM_WATCH=true

# Debounce window (seconds) before the watcher reconciles a burst of changes.
ENGRAM_WATCH_DEBOUNCE_SECONDS=0.5

# Comma-separated allowed origins for the browser extension and web UI (CORS).
# Leave empty if the UI is served same-origin and you don't use the extension
# cross-origin. Example: chrome-extension://<id>,https://engram.example.com
ENGRAM_CORS_ORIGINS=

# --- OAuth (optional; needed to connect from claude.ai as a Custom Connector) ---
# Public HTTPS origin where this server is reachable (no trailing path). Setting
# it turns on the embedded OAuth 2.1 authorization server and becomes the token
# issuer / resource identifier. Must be HTTPS in production (localhost allowed for
# testing). Leave empty to keep static-token-only auth. Example:
# ENGRAM_PUBLIC_URL=https://engram.example.com
ENGRAM_PUBLIC_URL=

# Password for the OAuth login/consent page. REQUIRED whenever ENGRAM_PUBLIC_URL
# is set — it stops anyone who can reach the public URL from minting a token.
# Use a long random secret, e.g.: openssl rand -hex 32
ENGRAM_OAUTH_PASSWORD=

# Log verbosity: debug | info | warning | error
ENGRAM_LOG_LEVEL=info
